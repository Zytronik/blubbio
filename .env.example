# -------------------------
# DATABASE
# -------------------------
# PostgreSQL connection string
# Used by Prisma to connect to your database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"


# -------------------------
# AUTH / JWT
# -------------------------
# Secret used to sign JWT tokens
JWT_SECRET="your-super-secret-key"

# Token expiration time (e.g. 10d, 24h, 60m)
JWT_EXI="10d"


# -------------------------
# VERCEL BLOB STORAGE
# -------------------------
# Token for DEV environment blob storage
BLOB_TOKEN_DEV="vercel_blob_rw_xxxxxxxxx"

# Token for PROD environment blob storage
BLOB_TOKEN_PROD="vercel_blob_rw_xxxxxxxxx"


# -------------------------
# APP ENVIRONMENT
# -------------------------
# Defines environment: development | production
NODE_ENV="development"


# -------------------------
# FRONTEND
# -------------------------
# URL of your frontend (used for CORS, links, etc.)
FRONTEND_URL="http://localhost:8080"


# -------------------------
# MAIL CONFIG (SMTP)
# -------------------------
# SMTP server port
MAIL_PORT="587"

# SMTP host
MAIL_HOST="smtp.office365.com"

# Email account username
MAIL_USER="your@email.com"

# Email account password or app password
MAIL_PASS="your-password"

# Whether to use secure connection (true for port 465, false for 587)
MAIL_SECURE="false"